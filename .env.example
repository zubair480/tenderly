# Do not add real credentials to this file. Use the ignored root .env locally
# and DigitalOcean App Platform secrets in production.
GRADIENT_API_KEY=
GRADIENT_MODEL=llama-4-maverick
GRADIENT_BASE_URL=https://inference.do-ai.run/v1

# SF DataSF Socrata 311 dataset (no key required)
SOCRATA_BASE_URL=https://data.sfgov.org/resource/vw6y-z8j6.json
NEEDS_CACHE_TTL_SECONDS=600

# Opportunity catalog / ingestion
DATABASE_URL=postgresql://doadmin:password@database-host:25060/defaultdb?sslmode=require
OPPORTUNITY_INGESTION_ENABLED=true

# Server
PORT=8080
